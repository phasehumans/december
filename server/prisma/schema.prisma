generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  username      String    @unique
  email         String    @unique
  password      String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  emailVerified Boolean   @default(false)
  googleId      String?
  otpExpiresAt  DateTime?
  otpHash       String?

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  githubToken     String?
  githubUsername  String?
  githubConnected Boolean @default(false)

  vercelConnected       Boolean @default(false)
  vercelAccessToken     String?
  vercelTeamId          String?
  vercelConfigurationId String?

  supabaseConnected      Boolean   @default(false)
  supabaseAccessToken    String?   @db.Text
  supabaseRefreshToken   String?   @db.Text
  supabaseTokenExpiresAt DateTime?
  supabaseTokenScope     String?
  supabaseUserId         String?
  supabaseConnectedAt    DateTime?

  notionAccessToken   String?
  notionWorkspaceId   String?
  notionWorkspaceName String?

  figmaConnected      Boolean   @default(false)
  figmaAccessToken    String?   @db.Text
  figmaRefreshToken   String?   @db.Text
  figmaTokenExpiresAt DateTime?
  figmaConnectedAt    DateTime?

  notifyProjectActivity Boolean @default(true)
  notifyProductUpdates  Boolean @default(false)
  notifySecurityAlerts  Boolean @default(true)

  chatSuggestions Boolean         @default(false)
  generationSound GenerationSound @default(FIRST_GENERATION)

  design String?
  hasCompletedOnboarding Boolean @default(false)

  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(FREE)
  subscriptionPlan   SubscriptionPlan   @default(FREE)
  currentPeriodEnd   DateTime?
  creditBalance      Int                @default(0)
  giftedCredits      Int                @default(0)

  sessions      Session[]
  projects      Project[]
  imports       ProjectImport[]
  likedProjects ProjectLike[]
  notifications Notification[]
  subscription  Subscription?
  usageEvents   UsageEvent[]
  redeemClaims  RedeemCodeClaim[]
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(INFO)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model Session {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, isRevoked])
}

model Project {
  id                 String          @id @default(uuid())
  name               String
  prompt             String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  userId             String
  description        String?
  isStarred          Boolean         @default(false)
  isSharedAsTemplate Boolean         @default(false)
  isFeatured         Boolean         @default(false)
  projectCategory    ProjectCategory @default(NONE)
  projectStatus      ProjectStatus   @default(DRAFT)
  currentVersionId   String?
  versionCount       Int             @default(0)
  previewImageKey    String?

  githubRepoName     String?
  githubRepoOwner    String?
  githubRepoUrl      String?
  githubLastSyncedAt DateTime?

  currentVersion ProjectVersion?  @relation("ProjectCurrentVersion", fields: [currentVersionId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       ProjectMessage[]
  versions       ProjectVersion[] @relation("ProjectVersions")
  likes          ProjectLike[]
  imports        ProjectImport[]
  usageEvents    UsageEvent[]

  @@index([userId, updatedAt])
  @@index([isSharedAsTemplate, updatedAt])
  @@index([isSharedAsTemplate, isFeatured, updatedAt])
}

model ProjectVersion {
  id                      String               @id @default(uuid())
  versionNumber           Int
  label                   String?
  sourcePrompt            String
  summary                 String?
  status                  ProjectVersionStatus @default(GENERATING)
  objectStoragePrefix     String
  manifestJson            Json
  canvasStateJson         Json?
  canvasAssetManifestJson Json?
  intentJson              Json?
  planJson                Json?
  isDatabaseEnabled       Boolean              @default(false)
  databaseUrl             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  projectId               String

  currentForProjects Project[]        @relation("ProjectCurrentVersion")
  imports            ProjectImport[]
  messages           ProjectMessage[]
  project            Project          @relation("ProjectVersions", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId, createdAt])
}

model ProjectMessage {
  id               String             @id @default(uuid())
  role             ProjectMessageRole
  content          String
  status           String?
  sequence         Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  projectId        String
  projectVersionId String

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectVersion ProjectVersion @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@unique([projectVersionId, sequence])
}

model ProjectImport {
  id               String              @id @default(uuid())
  userId           String
  sourceType       ProjectImportSource
  sourceUrl        String?
  sourceFileName   String?
  bucket           String?
  objectPrefix     String?
  status           ProjectImportStatus @default(PENDING)
  framework        String?
  projectId        String?
  projectVersionId String?
  previewUrl       String?
  errorMessage     String?
  errorsJson       Json?
  attempts         Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectVersion ProjectVersion? @relation(fields: [projectVersionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([projectId])
  @@index([projectVersionId])
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  isLiked   Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([projectId, isLiked])
}

model Subscription {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider               String
  providerSubscriptionId String  @unique
  providerCustomerId     String?
  providerPlanId         String

  status ProviderSubscriptionStatus
  plan   SubscriptionPlan

  cancelAtPeriodEnd Boolean @default(false)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UsageEvent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  model String

  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  totalTokens  Int @default(0)

  costInCents Int @default(0)

  projectId String?
  chatId    String?

  externalRequestId String?  @unique
  periodStart       DateTime
  periodEnd         DateTime
  metadata          Json?
  createdAt         DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, periodStart])
  @@index([userId, periodStart, createdAt])
  @@index([projectId, createdAt])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum GenerationSound {
  FIRST_GENERATION
  ALWAYS
  NEVER
}

enum ProjectStatus {
  DRAFT
  GENERATING
  READY
  DEPLOYED
  FAILED
}

enum ProjectVersionStatus {
  GENERATING
  READY
  FAILED
}

enum ProjectMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ProjectImportSource {
  GITHUB
  ZIP
}

enum ProjectImportStatus {
  PENDING
  VALIDATING
  UPLOADING
  STARTING_RUNTIME
  READY
  FAILED
}

enum ProjectCategory {
  LANDING_PAGE
  DASHBOARD
  PORTFOLIO_BLOG
  SAAS_APP
  ECOMMERCE
  NONE
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  FREE
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ProviderSubscriptionStatus {
  ACTIVE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  TRIALING
  UNPAID
}

model RedeemCode {
  id              String            @id @default(uuid())
  codeHash        String            @unique // SHA-256 hash of normalized code
  creditAmount    Int // amount to grant in cents
  maxRedemptions  Int? // null means unlimited
  redemptionCount Int               @default(0)
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  claims          RedeemCodeClaim[]
}

model RedeemCodeClaim {
  id           String   @id @default(uuid())
  redeemCodeId String
  userId       String
  redeemedAt   DateTime @default(now())

  redeemCode RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([redeemCodeId, userId])
  @@index([userId])
}
