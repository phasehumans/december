{
    "name": "@december/cli",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "module": "src/index.ts",
    "bin": {
        "december": "./dist/index.js"
    },
    "scripts": {
        "dev": "bun run src/index.ts",
        "build": "bun build ./src/index.ts --outdir ./dist --target node",
        "compile": "bun build --compile --minify ./src/index.ts --outfile ./dist/december"
    },
    "dependencies": {
        "commander": "^12.1.0",
        "ink": "^5.0.1",
        "react": "^18.2.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "@types/bun": "latest"
    }
}
