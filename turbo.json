{
    "$schema": "https://turbo.build/schema.json",
    "globalEnv": ["DATABASE_URL"],
    "tasks": {
        "db:generate": {
            "inputs": ["prisma/schema.prisma"],
            "outputs": ["packages/database/src/generated/client/**"]
        },
        "db:migrate": {
            "cache": false
        },
        "db:studio": {
            "cache": false,
            "persistent": true
        },
        "db:clear": {
            "cache": false
        },
        "build": {
            "dependsOn": ["^build", "db:generate"],
            "outputs": ["dist/**", "build/**", "target/**"]
        },
        "dev": {
            "dependsOn": ["db:generate"],
            "cache": false,
            "persistent": true
        },
        "start": {
            "dependsOn": ["db:generate"],
            "cache": false,
            "persistent": true
        },
        "lint": {
            "cache": true
        },
        "format": {
            "cache": true
        }
    }
}
