generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String              @id @default(uuid())
  name                   String
  email                  String              @unique
  password               String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  emailVerified          Boolean             @default(false)
  googleId               String?
  otpExpiresAt           DateTime?
  otpHash                String?
  githubId               String?
  githubToken            String?
  githubUsername         String?
  githubConnected        Boolean             @default(false)
  username               String              @unique
  notifyProductUpdates   Boolean             @default(false)
  notifyProjectActivity  Boolean             @default(true)
  notifySecurityAlerts   Boolean             @default(true)
  deletedAt              DateTime?
  chatSuggestions        Boolean             @default(false)
  generationSound        GenerationSound     @default(FIRST_GENERATION)
  isDeleted              Boolean             @default(false)
  avatarUrl              String?
  vercelAccessToken      String?
  vercelConnected        Boolean             @default(false)
  vercelTeamId           String?
  vercelConfigurationId  String?
  notionAccessToken      String?
  notionWorkspaceId      String?
  notionWorkspaceName    String?
  supabaseAccessToken    String?
  supabaseConnected      Boolean             @default(false)
  supabaseConnectedAt    DateTime?
  supabaseRefreshToken   String?
  supabaseTokenExpiresAt DateTime?
  supabaseTokenScope     String?
  supabaseUserId         String?
  creditBalance          Int                 @default(0)
  design                 String?
  hasCompletedOnboarding Boolean             @default(false)
  skills                 String?
  feedbacks              Feedback[]
  notifications          Notification[]
  projects               Project[]
  imports                ProjectImport[]
  likedProjects          ProjectLike[]
  redeemClaims           RedeemCodeClaim[]
  authSessions           AuthSession[]
  sessions               Session[]
  walletTransactions     WalletTransaction[]
  usageEvents            UsageEvent[]
  collaborations         ProjectCollaborator[]
  deviceCodes            DeviceCode[]
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(INFO)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, isRevoked])
}

model Session {
  id        String       @id @default(uuid())
  userId    String
  projectId String?
  title     String?
  type      SessionType  @default(WEB)
  vmId      String?
  vmStatus  VmStatus     @default(STOPPED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
  @@index([projectId])
}

enum SessionType {
  WEB
  CLI
  SEARCH
}

enum VmStatus {
  PROVISIONING
  RUNNING
  STOPPED
  FAILED
}

model Project {
  id                     String               @id @default(uuid())
  name                   String
  prompt                 String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  userId                 String
  description            String?
  isStarred              Boolean              @default(false)
  projectStatus          ProjectStatus        @default(DRAFT)
  currentVersionId       String?
  versionCount           Int                  @default(0)
  isSharedAsTemplate     Boolean              @default(false)
  projectCategory        ProjectCategory      @default(NONE)
  isFeatured             Boolean              @default(false)
  previewImageKey        String?
  githubLastSyncedAt     DateTime?
  githubRepoName         String?
  githubRepoOwner        String?
  githubRepoUrl          String?
  vercelDeploymentUrl    String?
  vercelLastDeployedAt   DateTime?
  vercelProjectId        String?
  vercelProjectName      String?
  decemberDeploymentUrl  String?
  decemberLastDeployedAt DateTime?
  minioPrefix            String?
  sessionMemories        AgentSessionMemory[]
  currentVersion         ProjectVersion?      @relation("ProjectCurrentVersion", fields: [currentVersionId], references: [id])
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  imports                ProjectImport[]
  likes                  ProjectLike[]
  memories               ProjectMemory[]
  sessions               Session[]
  versions               ProjectVersion[]     @relation("ProjectVersions")
  usageEvents            UsageEvent[]
  collaborators          ProjectCollaborator[]

  @@index([userId, updatedAt])
  @@index([isSharedAsTemplate, updatedAt])
  @@index([isSharedAsTemplate, isFeatured, updatedAt])
}

model ProjectVersion {
  id                      String               @id @default(uuid())
  versionNumber           Int
  label                   String?
  sourcePrompt            String
  summary                 String?
  status                  ProjectVersionStatus @default(GENERATING)
  objectStoragePrefix     String
  manifestJson            Json
  intentJson              Json?
  planJson                Json?
  isDatabaseEnabled       Boolean              @default(false)
  databaseUrl             String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  projectId               String
  canvasStateJson         Json?
  canvasAssetManifestJson Json?
  currentForProjects      Project[]            @relation("ProjectCurrentVersion")
  imports                 ProjectImport[]
  messages                Message[]
  project                 Project              @relation("ProjectVersions", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, versionNumber])
  @@index([projectId, createdAt])
}

model ProjectMemory {
  id        String   @id @default(uuid())
  projectId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
}

model AgentSessionMemory {
  id             String   @id @default(uuid())
  projectId      String
  versionId      String
  errorSignature String
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, versionId])
}

model Message {
  id               String             @id @default(uuid())
  role             MessageRole
  content          String
  status           String?
  sequence         Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  sessionId        String
  projectVersionId String?

  session          Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  projectVersion   ProjectVersion?    @relation(fields: [projectVersionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
}

model ProjectImport {
  id               String              @id @default(uuid())
  userId           String
  sourceType       ProjectImportSource
  sourceUrl        String?
  sourceFileName   String?
  bucket           String?
  objectPrefix     String?
  status           ProjectImportStatus @default(PENDING)
  framework        String?
  projectId        String?
  projectVersionId String?
  previewUrl       String?
  errorMessage     String?
  errorsJson       Json?
  attempts         Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  project          Project?            @relation(fields: [projectId], references: [id])
  projectVersion   ProjectVersion?     @relation(fields: [projectVersionId], references: [id])
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([projectId])
  @@index([projectVersionId])
}

model ProjectLike {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())
  isLiked   Boolean
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@index([projectId, isLiked])
}

model ProjectCollaborator {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@unique([projectId, email])
  @@index([projectId])
  @@index([userId])
  @@index([email])
}

model WalletTransaction {
  id                String          @id @default(uuid())
  userId            String
  amountInCents     Int
  currency          String          @default("USD")
  provider          PaymentProvider
  providerOrderId   String? // Razorpay order_id or Coinbase charge_id
  providerPaymentId String? // Razorpay payment_id
  status            PaymentStatus   @default(PENDING)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PaymentProvider {
  RAZORPAY
  COINBASE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model UsageEvent {
  id                String   @id @default(uuid())
  userId            String
  model             String
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  totalTokens       Int      @default(0)
  costInCents       Int      @default(0)
  projectId         String?
  chatId            String?
  externalRequestId String?  @unique
  metadata          Json?
  createdAt         DateTime @default(now())
  periodStart       DateTime
  periodEnd         DateTime
  project           Project? @relation(fields: [projectId], references: [id])
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId, periodStart])
  @@index([userId, periodStart, createdAt])
  @@index([projectId, createdAt])
  @@index([createdAt])
}

model RedeemCode {
  id              String            @id @default(uuid())
  codeHash        String            @unique
  creditAmount    Int
  maxRedemptions  Int?
  redemptionCount Int               @default(0)
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  claims          RedeemCodeClaim[]
}

model RedeemCodeClaim {
  id           String     @id @default(uuid())
  redeemCodeId String
  userId       String
  redeemedAt   DateTime   @default(now())
  redeemCode   RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([redeemCodeId, userId])
  @@index([userId])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  rating    String?
  feedback  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}



enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum GenerationSound {
  FIRST_GENERATION
  ALWAYS
  NEVER
}

enum ProjectStatus {
  DRAFT
  GENERATING
  READY
  DEPLOYED
  FAILED
}

enum ProjectVersionStatus {
  GENERATING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ProjectImportSource {
  GITHUB
  ZIP
}

enum ProjectImportStatus {
  PENDING
  VALIDATING
  UPLOADING
  STARTING_RUNTIME
  READY
  FAILED
}

enum ProjectCategory {
  LANDING_PAGE
  DASHBOARD
  PORTFOLIO_BLOG
  SAAS_APP
  ECOMMERCE
  NONE
}

model DeviceCode {
  id         String           @id @default(uuid())
  deviceCode String           @unique
  userCode   String           @unique
  userId     String?
  expiresAt  DateTime
  status     DeviceCodeStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceCode])
  @@index([userCode])
  @@index([userId])
}

enum DeviceCodeStatus {
  PENDING
  APPROVED
  EXPIRED
}
