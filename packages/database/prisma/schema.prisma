generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String          @id @default(uuid())
  name                   String
  email                  String          @unique
  password               String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  emailVerified          Boolean         @default(false)
  googleId               String?
  otpExpiresAt           DateTime?
  otpHash                String?
  githubId               String?
  githubToken            String?
  githubUsername         String?
  githubConnected        Boolean         @default(false)
  username               String          @unique
  notifyProductUpdates   Boolean         @default(false)
  notifyProjectActivity  Boolean         @default(true)
  notifySecurityAlerts   Boolean         @default(true)
  deletedAt              DateTime?
  chatSuggestions        Boolean         @default(false)
  generationSound        GenerationSound @default(FIRST_GENERATION)
  isDeleted              Boolean         @default(false)
  vercelAccessToken      String?
  vercelConnected        Boolean         @default(false)
  vercelTeamId           String?
  vercelConfigurationId  String?
  notionAccessToken      String?
  notionWorkspaceId      String?
  notionWorkspaceName    String?
  supabaseAccessToken    String?
  supabaseConnected      Boolean         @default(false)
  supabaseConnectedAt    DateTime?
  supabaseRefreshToken   String?
  supabaseTokenExpiresAt DateTime?
  supabaseTokenScope     String?
  supabaseUserId         String?
  creditBalance          Int             @default(0)
  hasCompletedOnboarding Boolean         @default(false)
  welcomeCardDone        Boolean         @default(false)
  githubCardDone         Boolean         @default(false)
  feedbackCardDone       Boolean         @default(false)

  notifications      Notification[]
  projects           Project[]
  imports            SessionImport[]
  authSessions       AuthSession[]
  sessions           Session[]
  walletTransactions WalletTransaction[]
  usageEvents        UsageEvent[]
  collaborations     SessionCollaborator[]
  deviceCodes        DeviceCode[]
  redeemClaims       RedeemCodeClaim[]
  githubInstallations GithubAppInstallation[]
  secrets            Secret[]
  feedbacks          Feedback[]
  pullRequestReviews PullRequestReview[]
  reviewPreference   ReviewPreference?
  wikis              RepositoryWiki[]
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(INFO)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isRevoked        Boolean   @default(false)
  revokedAt        DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, isRevoked])
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[]

  @@index([userId, updatedAt])
}

model Session {
  id                   String      @id @default(uuid())
  title                String?
  description          String?
  userId               String
  projectId            String?
  type                 SessionType @default(WEB)
  vmId                 String?
  vmStatus             VmStatus    @default(STOPPED)
  isArchived           Boolean     @default(false)
  tags                 String[]
  minioPrefix          String?
  githubLastSyncedAt   DateTime?
  githubRepoName       String?
  githubRepoOwner      String?
  githubRepoUrl        String?
  vercelDeploymentUrl  String?
  vercelLastDeployedAt DateTime?
  vercelProjectId      String?
  vercelProjectName    String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?              @relation(fields: [projectId], references: [id], onDelete: SetNull)
  messages        Message[]
  settings        SessionSettings?
  reviews         ReviewComment[]
  imports         SessionImport[]
  memories        SessionMemory[]
  sessionMemories AgentSessionMemory[]
  collaborators      SessionCollaborator[]
  usageEvents        UsageEvent[]
  pullRequestReviews PullRequestReview[]

  @@index([userId])
  @@index([projectId])
}

model SessionSettings {
  id        String   @id @default(uuid())
  sessionId String   @unique
  config    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ReviewComment {
  id              String   @id @default(uuid())
  sessionId       String
  content         String
  prUrl           String?
  githubCommentId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum WikiStatus {
  IDLE
  GENERATING
  COMPLETED
  FAILED
}

model RepositoryWiki {
  id           String     @id @default(uuid())
  userId       String
  repoFullName String
  repoOwner    String
  repoName     String
  status       WikiStatus @default(IDLE)
  isPinned     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages WikiPage[]

  @@unique([userId, repoFullName])
  @@index([userId])
}

model WikiPage {
  id        String         @id @default(uuid())
  wikiId    String
  slug      String
  title     String
  content   String         @db.Text
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  wiki RepositoryWiki @relation(fields: [wikiId], references: [id], onDelete: Cascade)

  @@unique([wikiId, slug])
  @@index([wikiId])
}

enum SessionType {
  WEB
  CLI
  SEARCH
}

enum VmStatus {
  PROVISIONING
  RUNNING
  STOPPED
  FAILED
}

model SessionMemory {
  id        String   @id @default(uuid())
  sessionId String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, key])
  @@index([sessionId])
}

model AgentSessionMemory {
  id             String   @id @default(uuid())
  sessionId      String
  errorSignature String
  createdAt      DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Message {
  id        String      @id @default(uuid())
  role      MessageRole
  content   String
  status    String?
  sequence  Int
  sessionId String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, sequence])
}

model SessionImport {
  id             String              @id @default(uuid())
  userId         String
  sessionId      String?
  sourceType     ProjectImportSource
  sourceUrl      String?
  sourceFileName String?
  bucket         String?
  objectPrefix   String?
  status         ProjectImportStatus @default(PENDING)
  framework      String?
  previewUrl     String?
  errorMessage   String?
  errorsJson     Json?
  attempts       Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([sessionId])
}

model SessionCollaborator {
  id        String   @id @default(uuid())
  sessionId String
  userId    String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@unique([sessionId, email])
  @@index([sessionId])
  @@index([userId])
  @@index([email])
}

model WalletTransaction {
  id                String          @id @default(uuid())
  userId            String
  amountInCents     Int
  currency          String          @default("USD")
  provider          PaymentProvider
  providerOrderId   String?
  providerPaymentId String?
  status            PaymentStatus   @default(PENDING)
  metadata          Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum PaymentProvider {
  RAZORPAY
  COINBASE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model UsageEvent {
  id                String   @id @default(uuid())
  userId            String
  sessionId         String?
  model             String
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  totalTokens       Int      @default(0)
  costInCents       Int      @default(0)
  chatId            String?
  externalRequestId String?  @unique
  metadata          Json?
  periodStart       DateTime
  periodEnd         DateTime
  createdAt         DateTime @default(now())

  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, periodStart])
  @@index([userId, periodStart, createdAt])
  @@index([sessionId, createdAt])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum GenerationSound {
  FIRST_GENERATION
  ALWAYS
  NEVER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ProjectImportSource {
  GITHUB
  ZIP
}

enum ProjectImportStatus {
  PENDING
  VALIDATING
  UPLOADING
  STARTING_RUNTIME
  READY
  FAILED
}

model DeviceCode {
  id         String           @id @default(uuid())
  deviceCode String           @unique
  userCode   String           @unique
  userId     String?
  expiresAt  DateTime
  status     DeviceCodeStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([deviceCode])
  @@index([userCode])
  @@index([userId])
}

enum DeviceCodeStatus {
  PENDING
  APPROVED
  EXPIRED
}

model RedeemCode {
  id              String            @id @default(uuid())
  codeHash        String            @unique
  creditAmount    Int
  maxRedemptions  Int?
  redemptionCount Int               @default(0)
  expiresAt       DateTime?
  metadata        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  claims          RedeemCodeClaim[]
}

model RedeemCodeClaim {
  id           String     @id @default(uuid())
  redeemCodeId String
  userId       String
  redeemedAt   DateTime   @default(now())
  redeemCode   RedeemCode @relation(fields: [redeemCodeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([redeemCodeId, userId])
  @@index([userId])
}

model GithubAppInstallation {
  id             String   @id @default(uuid())
  installationId String   @unique
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Secret {
  id        String   @id @default(uuid())
  userId    String
  name      String
  value     String   // Encrypted value
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Feedback {
  id        String   @id @default(uuid())
  userId    String
  rating    String?
  feedback  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum ReviewStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum ReviewProvider {
  GITHUB
  GITLAB
}

enum ReviewStrictness {
  LENIENT
  STANDARD
  STRICT
}

model PullRequestReview {
  id           String         @id @default(uuid())
  userId       String
  sessionId    String?
  prUrl        String
  prNumber     Int
  repository   String
  provider     ReviewProvider @default(GITHUB)
  title        String
  author       String
  authorAvatar String?
  status       ReviewStatus   @default(PENDING)
  isAutoReview Boolean        @default(false)
  score        Int            @default(0)
  summary      String?        @db.Text
  findings     Json           @default("[]")
  preferences  Json           @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([repository])
  @@index([status])
}

model ReviewPreference {
  id                 String           @id @default(uuid())
  userId             String           @unique
  autoReviewAgentPrs Boolean          @default(true)
  defaultStrictness  ReviewStrictness @default(STANDARD)
  focusAreas         String[]         @default(["SECURITY", "PERFORMANCE", "CLEAN_CODE"])
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

