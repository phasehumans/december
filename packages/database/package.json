{
    "name": "@december/database",
    "module": "src/index.ts",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:dev": "bunx dotenv-cli -e ../../.env -- prisma migrate dev",
        "db:migrate:test": "bunx dotenv-cli -e ../../.env.test -- prisma migrate deploy",
        "db:studio": "prisma studio --browser none --port 5555"
    },
    "dependencies": {
        "@prisma/client": "7.8.0",
        "@prisma/adapter-pg": "7.8.0",
        "@prisma/client-runtime-utils": "7.8.0",
        "pg": "^8.18.0"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/pg": "^8.16.0",
        "dotenv": "17.4.2",
        "prisma": "7.8.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
