{
    "name": "@december/proto",
    "version": "0.2.14",
    "private": true,
    "scripts": {
        "build": "mkdir -p src/generated && protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated ./runtime.proto --ts_proto_opt=outputServices=grpc-js,env=node,esModuleInterop=true",
        "typecheck": "tsc --noEmit"
    },
    "main": "src/generated/runtime.js",
    "types": "src/generated/runtime.ts",
    "exports": {
        "./*": "./src/generated/*"
    },
    "devDependencies": {
        "ts-proto": "^1.166.2"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.10.0",
        "protobufjs": "8.7.1"
    }
}
