{
    "name": "december",
    "type": "module",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "test": "turbo test",
        "prepare": "husky",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "linti": "eslint .",
        "lint:fix": "eslint . --fix",
        "docker:kill": "docker rm -f $(docker ps -aq --filter \"name=december-preview\")",
        "release": "bun scripts/release.ts",
        "tmuxlogs": "tmux capture-pane -p -S - > tmux.log"
    },
    "devDependencies": {
        "@changesets/cli": "2.31.0",
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.58.2",
        "@types/bun": "latest",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "dotenv": "^17.4.1",
        "eslint": "9",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.4",
        "turbo": "2.9.18",
        "typescript-eslint": "^8.59.3"
    },
    "peerDependencies": {
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,md,css,html,yml,yaml}": [
            "prettier --write"
        ]
    }
}
